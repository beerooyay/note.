{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "identifier": "com.blaize.note",
  "productName": "note.",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "note.",
        "width": 380,
        "height": 420,
        "minWidth": 360,
        "minHeight": 188,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}